# Environment overrides for /usr/local/sbin/n8n-backup
# Installed to /etc/default/n8n-backup by setup-server.sh.

# Directory where the backup repo is cloned
#BACKUP_REPO_DIR=/opt/n8n-backup

# Docker container name running n8n (check with: docker ps)
#N8N_CONTAINER=n8n

# Set to "false" to skip credentials backup (workflows only)
#INCLUDE_CREDENTIALS=true

# Branch to push backups to
#GIT_BRANCH=main

# Commit author identity
#GIT_USER_NAME=n8n-backup
#GIT_USER_EMAIL=n8n-backup@mocainteractive.com
