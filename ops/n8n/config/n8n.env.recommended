# Recommended environment variables for the n8n container.
#
# Add these to wherever the DigitalOcean 1-click image stores n8n's env vars.
# Most likely locations:
#   /root/.env
#   /opt/n8n/.env
#   /opt/n8n/docker-compose.yml  (under "environment:")
#
# After editing, restart n8n:   docker restart <n8n container>

# ---------------------------------------------------------------------------
# CRITICAL — encryption key
# ---------------------------------------------------------------------------
# Encrypts credentials at rest. The install already generated one — keep the
# existing value (do NOT regenerate, or every saved credential breaks).
# Copy the current value into Keeper/1Password as "n8n N8N_ENCRYPTION_KEY".
#N8N_ENCRYPTION_KEY=<keep existing value>

# ---------------------------------------------------------------------------
# Time zone (so schedule triggers fire when you expect)
# ---------------------------------------------------------------------------
GENERIC_TIMEZONE=Europe/Rome
TZ=Europe/Rome

# ---------------------------------------------------------------------------
# Execution log retention — without this the DB grows forever
# ---------------------------------------------------------------------------
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336          # hours = 14 days
EXECUTIONS_DATA_PRUNE_MAX_COUNT=50000

# ---------------------------------------------------------------------------
# Public URLs (also fixes webhook URLs printed in the UI)
# ---------------------------------------------------------------------------
N8N_HOST=n8n.mocainteractive.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.mocainteractive.com/
N8N_EDITOR_BASE_URL=https://n8n.mocainteractive.com/

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
N8N_SECURE_COOKIE=true
N8N_BASIC_AUTH_ACTIVE=false          # we have real user accounts now

# ---------------------------------------------------------------------------
# SMTP — required for user invites, password reset, 2FA recovery
# Replace with real credentials (Google Workspace, SendGrid, Mailgun, ...).
# ---------------------------------------------------------------------------
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=smtp.example.com
N8N_SMTP_PORT=587
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER="n8n MOCA <n8n@mocainteractive.com>"
N8N_SMTP_SSL=false

# ---------------------------------------------------------------------------
# Telemetry off
# ---------------------------------------------------------------------------
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=true
